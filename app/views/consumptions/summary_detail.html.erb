<div class="-mx-4 -mt-6 min-h-screen bg-stone-100 pb-24">
  <div class="bg-white px-4 pb-3 pt-5">
    <div class="flex items-center justify-between">
      <%= link_to summary_consumptions_path(
            month: @month.strftime("%Y-%m"),
            category_id: params[:category_id],
            sort: params[:sort],
            keyword: params[:keyword]
          ), 
          class: "text-stone-900" do %>

        <%= heroicon "chevron-left",
              type: :outline,
              class: "h-9 w-9 stroke-[2.5]" %>

      <% end %>

      <h1 class="text-xl font-bold"><%= @item_name %></h1>

      <div class="w-8"></div>
    </div>
  </div>

  <div class="bg-indigo-200 py-3 text-center font-semibold">
    <%= @display_month %> のまとめ
  </div>

  <div class="grid grid-cols-[1fr_100px] bg-indigo-100/70 px-8 py-3 font-bold">
    <div>消費日</div>
    <div class="text-center">消費数</div>
  </div>

  <% if @consumptions.any? %>
    <% @consumptions.each do |consumption| %>
      <div class="border-b border-stone-300 bg-white px-8 py-4">
        <div class="grid grid-cols-[1fr_100px] items-center">
          <div>
            <p class="font-semibold">
              <%= consumption.consumed_at.strftime("%Y/%m/%d") %>
            </p>

            <% if consumption.memo.present? %>
              <p class="mt-2 text-sm text-stone-500">
                <%= consumption.memo %>
              </p>
            <% end %>
          </div>

          <div class="text-center font-bold">
            <%= consumption.quantity %>
          </div>
        </div>
      </div>
    <% end %>

    <div class="mt-4 grid grid-cols-[1fr_100px] items-center bg-white px-8 py-4 font-bold">
      <div>合計</div>

      <div class="text-center">
        <%= @total_quantity %>
      </div>
    </div>
  <% else %>
    <div class="flex h-96 items-center justify-center text-xl font-bold">
      消費履歴なし
    </div>
  <% end %>
</div>