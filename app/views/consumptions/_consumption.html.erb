<div
  id="<%= dom_id(consumption) %>"
  class="grid grid-cols-[1fr_140px] items-center border-b border-stone-200 bg-white px-8 py-4">

  <div class="flex min-w-0 items-center gap-4">
    <%= link_to consumption_path(consumption),
          data: {
            turbo_method: :delete,
            turbo_confirm: "この消費履歴を削除しますか？"
          },
          class: "flex h-8 w-8 shrink-0 items-center justify-center text-stone-900",
          aria: { label: "#{consumption.item_name}の消費履歴を削除する" } do %>
      <%= heroicon "trash",
            type: :outline,
            class: "h-6 w-6" %>
    <% end %>

    <div class="min-w-0">
      <%= link_to consumption.item_name,
            edit_consumption_path(consumption),
            class: "block truncate text-base text-stone-900" %>

      <% if consumption.memo.present? %>
        <p class="mt-1 truncate text-xs text-stone-500">
          <%= consumption.memo %>
        </p>
      <% end %>
    </div>
  </div>

  <div class="flex items-center justify-center gap-5">
    <%= link_to increase_quantity_consumption_path(consumption),
          data: {
            turbo_method: :patch,
            turbo_stream: true
          },
          class: "flex h-7 w-7 items-center justify-center text-stone-900",
          aria: { label: "#{consumption.item_name}の消費数を増やす" } do %>
      <%= heroicon "plus-circle",
            type: :solid,
            class: "h-7 w-7" %>
    <% end %>

    <span class="min-w-4 text-center font-bold">
      <%= consumption.quantity %>
    </span>

    <% if consumption.quantity > 1 %>
      <%= link_to decrease_quantity_consumption_path(consumption),
            data: {
              turbo_method: :patch,
              turbo_stream: true
            },
            class: "flex h-7 w-7 items-center justify-center text-stone-900",
            aria: { label: "#{consumption.item_name}の消費数を減らす" } do %>
        <%= heroicon "minus-circle",
              type: :solid,
              class: "h-7 w-7" %>
      <% end %>
    <% else %>
      <span
        class="flex h-7 w-7 items-center justify-center text-stone-300"
        aria-label="消費数はこれ以上減らせません">
        <%= heroicon "minus-circle",
              type: :solid,
              class: "h-7 w-7" %>
      </span>
    <% end %>
  </div>
</div>