<h1 class="mb-6 text-2xl font-bold">消費履歴</h1>

<div class="space-y-3">
  <% @consumptions.each do |consumption| %>
    <div class="rounded-xl border border-stone-200 bg-white p-4 shadow-sm">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-lg font-semibold">
            <%= consumption.item_name %>
          </p>

          <span class="mt-1 inline-block rounded-full bg-stone-100 px-2 py-1 text-xs text-stone-600">
            <%= consumption.category_name %>
          </span>
        </div>

        <div class="text-right">
          <p class="text-sm text-stone-500">
            <%= consumption.consumed_at.strftime("%Y/%m/%d") %>
          </p>
        </div>
      </div>

      <div class="mt-4">
        <span class="inline-flex rounded-full bg-red-100 px-3 py-1 text-sm font-semibold text-red-700">
          消費数：<%= consumption.quantity %>
        </span>
      </div>

      <% if consumption.memo.present? %>
        <p class="mt-3 text-sm text-stone-600">
          <%= consumption.memo %>
        </p>
      <% end %>
    </div>
  <% end %>
</div>