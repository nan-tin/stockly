<div class="-mx-4 -mt-6 min-h-screen bg-stone-100 pb-24">
  <div class="relative bg-white px-4 py-4">
    <h1 class="text-center text-xl font-bold">
      消費履歴
    </h1>

    <%= link_to "月のまとめ",
          summary_consumptions_path(
            month: @month.strftime("%Y-%m")
          ),
          class: "absolute right-4 top-1/2 -translate-y-1/2 rounded-lg bg-stone-200 px-3 py-2 text-sm font-bold text-stone-900" %>
  </div>

  <div class="bg-indigo-200 py-3 text-center">
    <details class="relative inline-block">
      <summary class="list-none cursor-pointer font-semibold text-stone-900">
        ▼ <%= @display_month %>
      </summary>

      <div class="absolute left-1/2 z-30 mt-3 max-h-64 w-44 -translate-x-1/2 overflow-y-auto rounded-2xl bg-white text-sm shadow-lg ring-1 ring-stone-200">
        <% @available_months.each do |month| %>
          <%= link_to month.strftime("%Y年 %-m月"),
                consumptions_path(
                  month: month.strftime("%Y-%m")
                ),
                class: "block border-b border-stone-100 px-4 py-3 hover:bg-stone-50" %>
        <% end %>
      </div>
    </details>
  </div>

  <div class="grid grid-cols-7 bg-white px-4 py-2 text-center text-sm font-semibold">
    <% %w[日 月 火 水 木 金 土].each_with_index do |wday, index| %>
      <div class="<%= index == 0 ? 'text-red-500' : index == 6 ? 'text-blue-600' : 'text-stone-900' %>">
        <%= wday %>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-7 bg-white px-4 pb-4 text-center text-sm">
    <% @calendar_days.each do |day| %>
      <%= link_to consumptions_path(
            month: @month.strftime("%Y-%m"),
            date: day.strftime("%Y-%m-%d")
          ),
          class: "flex h-14 flex-col items-center justify-center rounded-lg #{day == @selected_date ? 'bg-stone-100 font-bold' : 'hover:bg-stone-100'}" do %>

        <% is_other_month = day.month != @month.month %>
        <% is_sunday = day.sunday? %>
        <% is_saturday = day.saturday? %>
        <% is_holiday = @holidays.include?(day) %>

        <% day_color =
          if is_other_month
            "text-stone-400"
          elsif is_sunday || is_holiday
            "text-red-500"
          elsif is_saturday
            "text-blue-600"
          else
            "text-stone-900"
          end
        %>

        <div class="relative flex h-12 items-center justify-center">
          <span class="<%= day_color %>">
            <%= day.day %>
          </span>

          <% if @daily_consumptions[day].present? %>
            <div class="absolute bottom-2 w-5 border-b-2 border-red-500"></div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="bg-indigo-200 px-8 py-3 text-center font-semibold">
    <%= @selected_date.strftime("%Y年 %-m月 %-d日") %>
  </div>

  <div class="grid grid-cols-[1fr_140px] bg-indigo-100/70 px-8 py-3 font-bold">
    <div class="flex items-center gap-4">
      <div class="h-8 w-8 shrink-0"></div>
      <span>アイテム名</span>
    </div>

    <div class="flex items-center justify-center">
      消費数
    </div>
  </div>

  <% if @selected_date_consumptions.any? %>
    <%= render @selected_date_consumptions %>
  <% else %>
    <div class="flex h-32 items-center justify-center text-base font-bold text-stone-900">
      消費履歴なし
    </div>
  <% end %>

  <div class="bg-stone-100 px-4 py-8">
    <div class="flex justify-center">
      <%= link_to new_consumption_path(
            date: @selected_date.strftime("%Y-%m-%d")
          ),
          class: "inline-flex items-center gap-3 rounded-full bg-white px-6 py-3 text-sm font-bold text-stone-900 shadow" do %>

        <span class="flex h-6 w-6 items-center justify-center rounded-full bg-stone-900 text-white">
          <%= heroicon "plus", type: :solid, class: "h-4 w-4" %>
        </span>

        <span>履歴にアイテムを追加する</span>
      <% end %>
    </div>
  </div>
</div>