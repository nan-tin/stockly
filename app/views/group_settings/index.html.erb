<div class="-mx-4 -mt-6 min-h-screen bg-stone-100 pb-28">
  <header class="bg-white px-4 py-5">
    <div class="flex items-center">
      <%= link_to settings_path do %>
        <%= heroicon "chevron-left",
              type: :outline,
              class: "h-6 w-6 text-stone-900" %>
      <% end %>

      <h1 class="mx-auto text-xl font-bold text-stone-900">
        共有設定
      </h1>
    </div>
  </header>

  <div class="space-y-4 px-4 py-5">

    <section>
      <h2 class="mb-2 px-4 text-sm text-stone-400">
        グループ情報
      </h2>

      <div class="bg-white">
        <div class="border-b border-stone-100 px-4 py-3">
          <p class="text-xs text-stone-400">
            招待コード
          </p>

          <p class="mt-1 font-semibold text-stone-900">
            <%= @group.invite_code %>
          </p>
        </div>

        <% if @group.owner == current_user %>
          <div data-controller="confirm-modal">
            <button
              type="button"
              data-action="confirm-modal#open"
              class="flex w-full items-center justify-between px-4 py-3 text-left text-stone-900"
            >
              <span>招待コードを再発行する</span>

              <%= heroicon "arrow-path",
                    type: :outline,
                    class: "h-5 w-5 text-stone-400" %>
            </button>

            <%= render "shared/confirm_modal",
                  modal_id: "regenerate-invite-code-confirm-modal",
                  title: "招待コードを再発行",
                  message: "現在の招待コードは使用できなくなります。\n新しい招待コードを再発行しますか？",
                  confirm_text: "再発行する",
                  confirm_path: regenerate_invite_code_group_settings_path,
                  confirm_method: :patch %>
          </div>
        <% end %>
      </div>
    </section>

    <section>
      <h2 class="mb-2 px-4 text-sm text-stone-400">
        メンバー
      </h2>

      <div class="bg-white">

        <% @members.each do |member| %>

          <div class="border-b border-stone-100 px-4 py-3">

            <%= member.email %>

          </div>

        <% end %>

      </div>
    </section>

    <section>
      <h2 class="mb-2 px-4 text-sm text-stone-400">
        グループに参加
      </h2>

      <div class="bg-white">
        <%= link_to join_group_settings_path,
              class: "flex items-center justify-between px-4 py-3 text-stone-900" do %>
          <span>招待コードで参加する</span>

          <%= heroicon "chevron-right",
                type: :outline,
                class: "h-5 w-5 text-stone-400" %>
        <% end %>
      </div>
    </section>

    <% if @group.owner != current_user %>
      <section>
        <h2 class="mb-2 px-4 text-sm text-stone-400">
          共有グループ
        </h2>

        <div class="bg-white" data-controller="confirm-modal">
          <button
            type="button"
            data-action="confirm-modal#open"
            class="flex w-full items-center justify-between px-4 py-3 text-left text-red-600"
          >
            <span>グループから退出する</span>

            <%= heroicon "arrow-left-on-rectangle",
                  type: :outline,
                  class: "h-5 w-5 text-red-400" %>
          </button>

          <%= render "shared/confirm_modal",
                modal_id: "leave-shared-group-confirm-modal",
                title: "共有グループから退出",
                message: "共有グループから退出しますか？\n共有中の在庫・買うもの・消費履歴は閲覧できなくなります。\n退出後は新しい個人グループが作成されます。",
                confirm_text: "退出する",
                confirm_path: leave_group_settings_path,
                confirm_method: :delete %>
        </div>
      </section>
    <% end %>
  </div>
</div>