<!DOCTYPE html>
<html>
  <head>
    <title>Stockly</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen overflow-y-scroll bg-stone-50 text-stone-900">
    <% flash.each do |message_type, message| %>
      <div class="mx-auto mt-4 max-w-md rounded-lg bg-green-100 px-4 py-3 text-sm text-green-800">
        <%= message %>
      </div>
    <% end %>

    <main class="mx-auto min-h-screen max-w-md px-4 pb-24 pt-6">
      <%= yield %>
    </main>

    <% if user_signed_in? %>
      <%= render "shared/bottom_nav" %>
    <% end %>
  </body>
</html>