<div
  data-confirm-modal-target="modal"
  data-action="keydown@window->confirm-modal#closeWithEscape"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="<%= modal_id %>-title"
>
  <div
    data-confirm-modal-target="backdrop"
    data-action="click->confirm-modal#closeOnBackdrop"
    class="absolute inset-0 flex items-center justify-center bg-black/40 px-5 opacity-0 transition-opacity duration-200"
  >
    <div
      data-confirm-modal-target="panel"
      class="w-full max-w-sm scale-95 rounded-2xl bg-white p-6 opacity-0 shadow-xl transition duration-200"
    >
      <h2
        id="<%= modal_id %>-title"
        class="text-center text-lg font-bold text-stone-900"
      >
        <%= title %>
      </h2>

      <p class="mt-3 whitespace-pre-line text-center text-sm leading-6 text-stone-600">
        <%= message %>
      </p>

      <div class="mt-6 flex gap-3">
        <button
          type="button"
          data-action="confirm-modal#close"
          class="flex-1 rounded-xl border border-stone-300 bg-white px-4 py-3 text-sm font-semibold text-stone-700"
        >
          キャンセル
        </button>

        <%= button_to confirm_text,
              confirm_path,
              method: confirm_method,
              form: {
                class: "flex-1"
              },
              class: "w-full rounded-xl bg-stone-900 px-4 py-3 text-sm font-semibold text-white" %>
      </div>
    </div>
  </div>
</div>