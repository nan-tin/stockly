<h1 class="mb-6 text-2xl font-bold">買うもの</h1>

<div class="mb-4 flex justify-end">
  <%= link_to "買うもの追加",
        new_shopping_item_path,
        class: "rounded-lg bg-stone-900 px-4 py-2 text-sm font-semibold text-white" %>
</div>

<div class="space-y-3">
  <% @shopping_items.each do |shopping_item| %>
    <div class="rounded-xl border border-stone-200 bg-white p-4 shadow-sm">
      <div class="mb-2 flex items-center gap-2">
        <p class="truncate text-lg font-semibold"><%= shopping_item.name %></p>

        <span class="rounded-full bg-stone-100 px-2 py-1 text-xs text-stone-600">
          <%= shopping_item.category.name %>
        </span>
      </div>

      <div class="mt-2">
        <span class="inline-flex rounded-full bg-blue-100 px-3 py-1 text-sm font-semibold text-blue-700">
          購入予定数：<%= shopping_item.quantity %>
        </span>
      </div>

      <% if shopping_item.memo.present? %>
        <p class="mt-3 text-sm text-stone-600">
          <%= shopping_item.memo %>
        </p>
      <% end %>

      <div class="mt-4 grid grid-cols-3 gap-2">
        <%= button_to "購入済み",
              purchase_shopping_item_path(shopping_item),
              method: :patch,
              class: "w-full rounded-lg bg-green-600 px-3 py-2 text-sm font-semibold text-white" %>

        <%= link_to "編集",
              edit_shopping_item_path(shopping_item),
              class: "rounded-lg border border-blue-200 px-3 py-2 text-center text-sm font-semibold text-blue-600" %>

        <%= link_to "削除",
              shopping_item_path(shopping_item),
              class: "rounded-lg border border-red-200 px-3 py-2 text-center text-sm font-semibold text-red-600",
              data: {
                turbo_method: :delete,
                turbo_confirm: "本当に削除しますか？"
              } %>
      </div>
    </div>
  <% end %>
</div>