<div data-controller="select-all" class="-mx-4 -mt-6 min-h-screen bg-stone-100 pb-24">
  <%= form_with url: bulk_purchase_shopping_items_path, method: :patch do %>
    <div class="relative bg-white px-4 pb-3 pt-5">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-10">
          <button
            type="button"
            data-action="click->select-all#toggleAll"
            class="flex h-10 w-10 items-center justify-center text-stone-900">
            <%= heroicon "check-circle", type: :outline, class: "h-7 w-7" %>
          </button>

          <%= button_tag type: "submit",
                formaction: bulk_destroy_shopping_items_path,
                formmethod: :post,
                name: "_method",
                value: "delete",
                class: "flex h-10 w-10 items-center justify-center text-stone-900",
                data: { turbo_confirm: "選択した買うものを削除しますか？" } do %>
            <%= heroicon "trash", type: :outline, class: "h-7 w-7" %>
          <% end %>
        </div>

        <h1 class="absolute left-1/2 -translate-x-1/2 text-xl font-bold">
          買う物
        </h1>

        <%= button_tag type: "submit",
              class: "inline-flex items-center gap-2 rounded-lg bg-stone-200 px-3 py-2 text-sm font-bold text-stone-900",
              data: { turbo_confirm: "選択した買うものを在庫へ追加しますか？" } do %>
          <span class="flex h-5 w-5 items-center justify-center rounded-full bg-stone-900 text-white">
            <%= heroicon "check", type: :solid, class: "h-3.5 w-3.5" %>
          </span>
          <span>購入済みにする</span>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-[1fr_140px] bg-indigo-200 px-8 py-3 font-bold">

      <div class="flex items-center gap-5">
        <div class="w-7"></div>
        <span>アイテム名</span>
      </div>

      <div class="flex justify-center">
        個数
      </div>

    </div>

    <% if @shopping_items.any? %>
      <%= render @shopping_items %>
    <% else %>
      <div class="flex h-72 items-center justify-center text-lg font-bold">
        買うものなし
      </div>
    <% end %>

    <div class="mt-10 flex justify-center">
      <%= link_to new_shopping_item_path,
            class: "inline-flex items-center gap-3 rounded-full bg-white px-6 py-3 text-sm font-bold text-stone-900 shadow" do %>
        <span class="flex h-6 w-6 items-center justify-center rounded-full bg-stone-900 text-white">
          <%= heroicon "plus", type: :solid, class: "h-4 w-4" %>
        </span>
        <span>買う物にアイテムを追加する</span>
      <% end %>
    </div>
  <% end %>
</div>