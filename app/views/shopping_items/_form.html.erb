<%= form_with model: @shopping_item, class: "space-y-5" do |f| %>
  <% if @shopping_item.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4 text-sm text-red-700">
      <p class="font-semibold">入力内容を確認してください</p>
      <ul class="mt-2 list-disc pl-5">
        <% @shopping_item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex justify-center">
    <div class="flex h-32 w-32 flex-col items-center justify-center rounded-2xl border border-stone-900 bg-white text-sm font-bold text-stone-900">
      <%= heroicon "photo",
            variant: :outline,
            options: { class: "h-8 w-8" } %>
      <span class="mt-2">画像追加</span>
    </div>
  </div>

  <div class="divide-y divide-stone-200 border-y border-stone-200">
    <div class="grid grid-cols-[90px_1fr] items-center py-3">
      <%= f.label :category_id, "カテゴリー", class: "text-sm font-bold" %>

      <div class="flex justify-end overflow-hidden">
        <div class="relative inline-block max-w-full">
          <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-sm text-stone-900">
            ▼
          </span>

          <%= f.collection_select :category_id,
                current_group.categories,
                :id,
                :name,
                {},
                class: "max-w-[220px] appearance-none truncate rounded-full border border-stone-900 bg-white py-2 pl-8 pr-5 text-sm font-semibold text-stone-900" %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-[90px_1fr] items-center py-3">
      <%= f.label :name, "商品名", class: "text-sm font-bold text-stone-900" %>
      <%= f.text_field :name,
            placeholder: "例：みかん",
            class: "w-full rounded-lg border border-stone-300 px-3 py-2 text-sm" %>
    </div>

    <div class="grid grid-cols-[90px_1fr] items-center py-3">
      <%= f.label :quantity, "購入数", class: "text-sm font-bold text-stone-900" %>
      <%= f.number_field :quantity,
            min: 1,
            class: "w-20 rounded-lg border border-stone-300 px-3 py-2 text-center text-sm" %>
    </div>

    <div class="grid grid-cols-[90px_1fr] py-3">
      <%= f.label :memo, "メモ", class: "text-sm font-bold text-stone-900" %>
      <%= f.text_area :memo,
            rows: 5,
            placeholder: "例：和歌山県産のみかん",
            class: "w-full resize-none rounded-lg border-0 px-0 py-0 text-sm focus:ring-0" %>
    </div>
  </div>

  <div class="flex gap-4 pt-4">
    <%= link_to "キャンセル",
          shopping_items_path,
          class: "flex-1 rounded-xl bg-stone-200 py-3 text-center text-sm font-bold text-blue-500" %>

    <%= f.submit @shopping_item.persisted? ? "更新" : "登録",
          class: "flex-1 rounded-xl bg-blue-500 py-3 text-sm font-bold text-white" %>
  </div>
<% end %>