<div class="mx-auto max-w-md">
  <div class="mb-8 text-center">
    <h1 class="text-3xl font-bold">Stockly</h1>
    <p class="mt-2 text-sm text-stone-600">在庫管理を、もっとシンプルに</p>
  </div>

  <div class="rounded-xl border border-stone-200 bg-white p-5 shadow-sm">
    <h2 class="mb-6 text-2xl font-bold">ログイン</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, "メールアドレス", class: "mb-1 block text-sm font-semibold text-stone-700" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "w-full rounded-lg border border-stone-300 px-3 py-2 text-sm" %>
      </div>

      <div>
        <%= f.label :password, "パスワード", class: "mb-1 block text-sm font-semibold text-stone-700" %>
        <%= f.password_field :password,
              autocomplete: "current-password",
              class: "w-full rounded-lg border border-stone-300 px-3 py-2 text-sm" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-stone-300" %>
          <%= f.label :remember_me, "ログイン状態を保持する", class: "text-sm text-stone-700" %>
        </div>
      <% end %>

      <%= f.submit "ログイン",
            class: "w-full rounded-lg bg-stone-900 px-4 py-3 text-sm font-semibold text-white" %>
    <% end %>

    <div class="my-5 flex items-center gap-3">
      <div class="h-px flex-1 bg-stone-200"></div>
      <span class="text-xs text-stone-400">または</span>
      <div class="h-px flex-1 bg-stone-200"></div>
    </div>

    <%= button_to "ゲストとして使ってみる",
          users_guest_sign_in_path,
          method: :post,
          class: "w-full rounded-lg border border-stone-300 bg-white px-4 py-3 text-sm font-semibold text-stone-800" %>

    <div class="mt-5 text-center text-sm">
      <%= render "users/shared/links" %>
    </div>
  </div>
</div>