<div class="mx-auto flex min-h-screen max-w-[390px] flex-col bg-stone-100">
  <header class="bg-white py-4 text-center shadow-sm">
    <div class="relative mx-auto max-w-sm">
      <%= link_to login_path, class: "absolute left-4 top-0 text-3xl leading-none text-stone-900" do %>
        <%= heroicon "chevron-left",
              variant: :outline,
              options: { class: "h-6 w-6" } %>
      <% end %>
      <h1 class="text-lg font-bold">新規登録</h1>
    </div>
  </header>

  <main class="flex flex-1 items-start justify-center px-6 pt-10">
    <div class="w-full rounded-xl bg-white px-6 py-7 shadow-sm">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <%= render "users/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, "メールアドレス", class: "mb-2 block text-sm font-semibold text-stone-800" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                class: "w-full rounded border border-stone-300 px-3 py-3 text-sm" %>
        </div>

        <div>
          <%= f.label :password, "パスワード", class: "mb-2 block text-sm font-semibold text-stone-800" %>
          <%= f.password_field :password,
                autocomplete: "new-password",
                placeholder: "8文字以上（半角英数字を含む）",
                class: "w-full rounded border border-stone-300 px-3 py-3 text-sm" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "パスワード（確認）", class: "mb-2 block text-sm font-semibold text-stone-800" %>
          <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                placeholder: "もう一度入力",
                class: "w-full rounded border border-stone-300 px-3 py-3 text-sm" %>
        </div>

        <%= f.submit "登録する",
              class: "w-full rounded bg-blue-500 px-4 py-3 text-sm font-bold text-white" %>
      <% end %>
    </div>
  </main>

  <footer class="bg-white py-4 text-center text-xs text-stone-900">
    <div class="space-x-2">
      <%= link_to "利用規約", terms_path %>
      <span>|</span>
      <%= link_to "プライバシーポリシー", privacy_path %>
      <span>|</span>
      <%= link_to "お問い合わせ", new_inquiry_path %>
    </div>
    <p class="mt-1">© 2026 Stockly</p>
  </footer>
</div>