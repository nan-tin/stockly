<h1 class="mb-6 text-2xl font-bold">設定</h1>

<div class="space-y-6">
  <section>
    <h2 class="mb-3 text-sm font-semibold text-stone-500">アプリ設定</h2>

    <div class="overflow-hidden rounded-xl border border-stone-200 bg-white shadow-sm">
      <%= link_to "カテゴリー管理",
            categories_path,
            class: "block border-b border-stone-100 px-4 py-4 text-sm font-semibold text-stone-800" %>

      <%= link_to "お問い合わせ",
            new_inquiry_path,
            class: "block border-b border-stone-100 px-4 py-4 text-sm font-semibold text-stone-800" %>
    </div>
  </section>

  <section>
    <h2 class="mb-3 text-sm font-semibold text-stone-500">このアプリについて</h2>

    <div class="overflow-hidden rounded-xl border border-stone-200 bg-white shadow-sm">
      <%= link_to "利用規約",
            terms_path,
            class: "block border-b border-stone-100 px-4 py-4 text-sm font-semibold text-stone-800" %>

      <%= link_to "プライバシーポリシー",
            privacy_path,
            class: "block px-4 py-4 text-sm font-semibold text-stone-800" %>
    </div>
  </section>

  <section>
    <h2 class="mb-3 text-sm font-semibold text-stone-500">アカウント</h2>

    <div class="overflow-hidden rounded-xl border border-stone-200 bg-white shadow-sm">
      <%= link_to "ログアウト",
            destroy_user_session_path,
            data: {
              turbo_method: :delete,
              turbo_confirm: "本当にログアウトしますか？"
            },
            class: "block px-4 py-4 text-sm font-semibold text-red-600" %>
    </div>
  </section>
</div>