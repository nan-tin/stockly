<div class="-mx-4 -mt-6 min-h-screen bg-stone-100 pb-28">
  <header class="bg-white px-4 py-5 text-center">
    <h1 class="text-xl font-bold text-stone-900">設定</h1>
  </header>

  <div class="space-y-4 px-4 py-5">
    <section>
      <h2 class="mb-2 px-4 text-sm text-stone-400">
        カテゴリー追加
      </h2>

      <div class="bg-white">
        <% @categories.each do |category| %>
          <%= link_to edit_category_path(category),
                class: "flex items-center justify-between border-b border-stone-100 px-4 py-3 text-stone-900" do %>
            <span><%= category.name %></span>

            <%= heroicon "chevron-right",
                  type: :outline,
                  class: "h-5 w-5 text-stone-400" %>
          <% end %>
        <% end %>

        <%= link_to new_category_path,
              class: "flex items-center gap-2 px-4 py-3 text-blue-500" do %>
          <%= heroicon "plus",
                type: :outline,
                class: "h-6 w-6" %>

          <span>カテゴリー追加</span>
        <% end %>
      </div>
    </section>

    <% unless current_user.guest? %>
      <section>
        <h2 class="mb-2 px-4 text-sm text-stone-400">
          共有設定
        </h2>

        <div class="bg-white">
          <div class="flex items-center justify-between px-4 py-3 text-stone-900">
            <span>家族・複数人で使う</span>

            <%= heroicon "chevron-right",
                  type: :outline,
                  class: "h-5 w-5 text-stone-400" %>
          </div>
        </div>
      </section>
    <% end %>

    <section>
      <h2 class="mb-2 px-4 text-sm text-stone-400">
        アカウントの設定
      </h2>

      <div class="bg-white">
        <% if current_user.guest? %>
          <div class="flex items-center justify-between border-b border-stone-100 px-4 py-3 text-stone-900">
            <span>データをすべて削除する</span>

            <%= heroicon "chevron-right",
                  type: :outline,
                  class: "h-5 w-5 text-stone-400" %>
          </div>

          <div class="flex items-center justify-between border-b border-stone-100 px-4 py-3 text-stone-900">
            <span>アカウントの削除・退会</span>

            <%= heroicon "chevron-right",
                  type: :outline,
                  class: "h-5 w-5 text-stone-400" %>
          </div>

          <div class="flex items-center justify-between px-4 py-3 text-stone-900">
            <span>会員登録を行う</span>

            <%= heroicon "chevron-right",
                  type: :outline,
                  class: "h-5 w-5 text-stone-400" %>
          </div>
        <% else %>
          <div class="flex items-center justify-between border-b border-stone-100 px-4 py-3 text-stone-900">
            <span>データをすべて削除する</span>

            <%= heroicon "chevron-right",
                  type: :outline,
                  class: "h-5 w-5 text-stone-400" %>
          </div>

          <div class="flex items-center justify-between border-b border-stone-100 px-4 py-3 text-stone-900">
            <span>アカウントの削除・退会</span>

            <%= heroicon "chevron-right",
                  type: :outline,
                  class: "h-5 w-5 text-stone-400" %>
          </div>

          <% if current_user.google_login? %>
            <div class="border-b border-stone-100 px-4 py-3">
              <p class="text-stone-900">
                <%= current_user.email %>
              </p>

              <p class="mt-1 text-xs text-stone-400">
                Googleアカウントでログイン中
              </p>
            </div>
          <% else %>
            <div class="flex items-center justify-between border-b border-stone-100 px-4 py-3 text-stone-900">
              <span>メールアドレスの変更</span>

              <%= heroicon "chevron-right",
                    type: :outline,
                    class: "h-5 w-5 text-stone-400" %>
            </div>

            <div class="flex items-center justify-between border-b border-stone-100 px-4 py-3 text-stone-900">
              <span>パスワード変更</span>

              <%= heroicon "chevron-right",
                    type: :outline,
                    class: "h-5 w-5 text-stone-400" %>
            </div>
          <% end %>

          <div data-controller="confirm-modal">
            <button
              type="button"
              data-action="confirm-modal#open"
              class="w-full text-left"
            >
              <div class="flex items-center justify-between px-4 py-4">
                <span class="text-sm font-semibold text-stone-900">
                  ログアウト
                </span>

                <%= heroicon "chevron-right",
                      type: :outline,
                      class: "h-5 w-5 text-stone-400" %>
              </div>
            </button>

            <%= render "shared/confirm_modal",
                  modal_id: "logout-confirm-modal",
                  title: "ログアウト",
                  message: "本当にログアウトしますか？",
                  confirm_text: "ログアウト",
                  confirm_path: destroy_user_session_path,
                  confirm_method: :delete %>
          </div>
        <% end %>
      </div>
    </section>

    <section>
      <h2 class="mb-2 px-4 text-sm text-stone-400">
        このアプリについて
      </h2>

      <div class="bg-white">
        <div class="flex items-center justify-between border-b border-stone-100 px-4 py-3 text-stone-900">
          <span>アプリの使い方</span>

          <%= heroicon "chevron-right",
                type: :outline,
                class: "h-5 w-5 text-stone-400" %>
        </div>

        <%= link_to new_inquiry_path,
              class: "flex items-center justify-between border-b border-stone-100 px-4 py-3 text-stone-900" do %>
          <span>お問い合わせ</span>

          <%= heroicon "chevron-right",
                type: :outline,
                class: "h-5 w-5 text-stone-400" %>
        <% end %>

        <%= link_to terms_path,
              class: "flex items-center justify-between border-b border-stone-100 px-4 py-3 text-stone-900" do %>
          <span>利用規約</span>

          <%= heroicon "chevron-right",
                type: :outline,
                class: "h-5 w-5 text-stone-400" %>
        <% end %>

        <%= link_to privacy_path,
              class: "flex items-center justify-between px-4 py-3 text-stone-900" do %>
          <span>プライバシーポリシー</span>

          <%= heroicon "chevron-right",
                type: :outline,
                class: "h-5 w-5 text-stone-400" %>
        <% end %>
      </div>
    </section>
  </div>
</div>