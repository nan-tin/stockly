<%= form_with model: item, class: "space-y-5" do |f| %>
  <% if item.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4 text-sm text-red-700">
      <p class="font-semibold">入力内容を確認してください</p>
      <ul class="mt-2 list-disc pl-5">
        <% item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div data-controller="image-preview" class="flex justify-center">
    <%= f.label :image,
          class: "flex h-32 w-32 cursor-pointer flex-col items-center justify-center overflow-hidden rounded-2xl border border-stone-900 bg-white text-sm font-bold text-stone-900" do %>

      <% if item.image.attached? %>
        <%= image_tag item.image,
              data: { image_preview_target: "preview" },
              class: "h-full w-full rounded-2xl bg-white object-contain" %>
      <% else %>
        <%= image_tag "",
              data: { image_preview_target: "preview" },
              class: "hidden h-full w-full rounded-2xl bg-white object-contain" %>
      <% end %>

      <div data-image-preview-target="placeholder"
          class="<%= item.image.attached? ? 'hidden' : 'flex' %> flex-col items-center">
        <%= heroicon "photo",
              variant: :outline,
              options: { class: "h-8 w-8" } %>
        <span class="mt-2">画像追加</span>
      </div>
    <% end %>

    <%= f.file_field :image,
          class: "hidden",
          data: {
            image_preview_target: "input",
            action: "change->image-preview#preview"
          } %>
  </div>

  <div>
    <%= f.label :category_id, "カテゴリー", class: "mb-2 block text-sm font-semibold text-stone-800" %>
    <%= f.collection_select :category_id,
          current_group.categories,
          :id,
          :name,
          {},
          class: "w-full rounded-lg border border-stone-300 px-3 py-3 text-sm" %>
  </div>

  <div>
    <%= f.label :name, "アイテム名", class: "mb-2 block text-sm font-semibold text-stone-800" %>
    <%= f.text_field :name,
          placeholder: "例：みかん",
          class: "w-full rounded-lg border border-stone-300 px-3 py-3 text-sm" %>
  </div>

  <div data-controller="quantity">
    <%= f.label :quantity, "在庫数", class: "mb-2 block text-sm font-semibold text-stone-800" %>
    <div class="flex items-center gap-3">
      <button
        type="button"
        id="decrease-button"
        data-action="click->quantity#decrease"
        class="flex h-10 w-10 items-center justify-center rounded-lg bg-stone-900 text-xl font-bold text-white">
        −
      </button>

      <%= f.number_field :quantity,
            min: 0,
            data: {
              quantity_target: "input"
            },
            class: "w-20 rounded-lg border border-stone-300 py-2 text-center text-lg" %>

      <button
        type="button"
        id="increase-button"
        data-action="click->quantity#increase"
        class="flex h-10 w-10 items-center justify-center rounded-lg bg-stone-900 text-xl font-bold text-white">
        ＋
      </button>
    </div>
  </div>

  <div>
    <%= f.label :purchased_at, "購入日", class: "mb-2 block text-sm font-semibold text-stone-800" %>
    <%= f.date_field :purchased_at,
          class: "w-full rounded-lg border border-stone-300 px-3 py-3 text-sm" %>
  </div>

  <div>
    <%= f.label :expired_at, "期限日", class: "mb-2 block text-sm font-semibold text-stone-800" %>
    <%= f.date_field :expired_at,
          class: "w-full rounded-lg border border-stone-300 px-3 py-3 text-sm" %>
  </div>

  <div>
    <%= f.label :memo, "メモ", class: "mb-2 block text-sm font-semibold text-stone-800" %>
    <%= f.text_area :memo,
          rows: 5,
          placeholder: "例：和歌山県産のみかん",
          class: "w-full rounded-lg border border-stone-300 px-3 py-3 text-sm" %>
  </div>

  <div class="flex gap-4 pt-6 pb-2">
    <%= link_to "キャンセル",
          items_path,
          class: "flex-1 rounded-xl border border-stone-300 bg-white py-3 text-center text-sm font-semibold text-stone-700 transition hover:bg-stone-50" %>

    <%= f.submit submit_text,
          class: "flex-1 rounded-xl bg-blue-500 py-3 text-sm font-semibold text-white transition hover:bg-blue-600" %>
  </div>
<% end %>