<div class="-mx-4 -mt-6 min-h-screen bg-stone-100 pb-24">
  <div class="bg-white px-4 pb-3 pt-5">
    <div class="flex items-center justify-between">
      <details class="relative">
        <summary class="list-none cursor-pointer rounded-full border border-stone-900 px-3 py-1 text-sm font-semibold">
          ▼
          <% if @selected_category_id.present? %>
            <%= @categories.find { |category| category.id.to_s == @selected_category_id.to_s }&.name %>
          <% else %>
            全てのアイテム
          <% end %>
        </summary>

        <div class="absolute left-0 z-30 mt-2 w-40 overflow-hidden rounded-2xl bg-white text-sm shadow-lg ring-1 ring-stone-200">
          <%= link_to "全てのアイテム",
                items_path(display: @display, sort: params[:sort]),
                class: "block border-b border-stone-100 px-4 py-3" %>

          <% @categories.each do |category| %>
            <%= link_to category.name,
                  items_path(category_id: category.id, display: @display, sort: params[:sort]),
                  class: "block border-b border-stone-100 px-4 py-3" %>
          <% end %>
        </div>
      </details>

      <div class="flex items-center gap-5">
        <%= link_to items_path(search: "true"), class: "text-stone-900" do %>
          <%= heroicon "magnifying-glass", type: :outline, class: "h-7 w-7" %>
        <% end %>

        <%= link_to items_path(
              category_id: params[:category_id],
              display: @display,
              sort: params[:sort],
              menu: "edit"
            ),
            class: "text-2xl font-bold leading-none" do %>
          ･･･
        <% end %>
      </div>
    </div>
  </div>

  <% if params[:search] == "true" || params[:keyword].present? %>
    <div class="bg-white px-4 py-3">
      <%= form_with url: items_path, method: :get, class: "flex items-center gap-3" do |f| %>
        <%= link_to items_path, class: "text-stone-900" do %>
          <span class="text-3xl leading-none">＜</span>
        <% end %>

        <div class="flex min-h-12 flex-1 items-center rounded-2xl bg-stone-100 px-3">
          <%= heroicon "magnifying-glass", type: :outline, class: "mr-2 h-6 w-6" %>
          <%= f.text_field :keyword,
                value: params[:keyword],
                placeholder: "アイテム名を入力",
                class: "w-full bg-transparent text-base outline-none" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% modal_wrapper_class = "fixed inset-0 z-40 flex items-start justify-center bg-black/20 px-5 pt-24" %>
  <% modal_panel_class = "w-full max-w-sm overflow-hidden rounded-3xl bg-white text-center shadow-xl" %>
  <% modal_title_class = "pt-4 text-lg font-bold text-stone-900" %>
  <% modal_subtitle_class = "pb-3 pt-1 text-sm text-stone-400" %>
  <% modal_link_class = "block border-t border-stone-200 px-4 py-4 text-center text-lg text-stone-900 hover:bg-stone-50" %>

  <% if params[:menu] == "edit" %>
    <div
      class="<%= modal_wrapper_class %>"
      data-controller="modal"
      data-action="click->modal#close keydown@window->modal#closeWithEscape"
      data-modal-close-url-value="<%= items_path(
        category_id: params[:category_id],
        display: @display,
        sort: params[:sort]
      ) %>">

      <div class="<%= modal_panel_class %>">
        <p class="<%= modal_title_class %>">編集操作</p>
        <p class="<%= modal_subtitle_class %>">操作を選択してください</p>

        <%= link_to "並び替えを行う",
              items_path(
                category_id: params[:category_id],
                display: @display,
                menu: "sort"
              ),
              class: modal_link_class %>

        <%= link_to "複数選択を行う",
              items_path(
                category_id: params[:category_id],
                display: @display,
                sort: params[:sort],
                select: "true"
              ),
              class: modal_link_class %>

        <%= link_to "表示変更を行う",
              items_path(
                category_id: params[:category_id],
                sort: params[:sort],
                menu: "display"
              ),
              class: modal_link_class %>

        <%= link_to "閉じる",
              items_path(
                category_id: params[:category_id],
                display: @display,
                sort: params[:sort]
              ),
              class: modal_link_class %>
      </div>
    </div>
  <% end %>

  <% if params[:menu] == "sort" %>
    <div
      class="<%= modal_wrapper_class %>"
      data-controller="modal"
      data-action="click->modal#close keydown@window->modal#closeWithEscape"
      data-modal-close-url-value="<%= items_path(
        category_id: params[:category_id],
        display: @display,
        sort: params[:sort]
      ) %>">

      <div class="<%= modal_panel_class %>">
        <p class="<%= modal_title_class %>">並び替えを行う</p>
        <p class="<%= modal_subtitle_class %>">操作を選択してください</p>

        <%= link_to "購入が新しい順",
              items_path(
                category_id: params[:category_id],
                display: @display,
                sort: "purchased_desc"
              ),
              class: modal_link_class %>

        <%= link_to "購入が古い順",
              items_path(
                category_id: params[:category_id],
                display: @display,
                sort: "purchased_asc"
              ),
              class: modal_link_class %>

        <%= link_to "在庫数が多い順",
              items_path(
                category_id: params[:category_id],
                display: @display,
                sort: "quantity_desc"
              ),
              class: modal_link_class %>

        <%= link_to "在庫数が少ない順",
              items_path(
                category_id: params[:category_id],
                display: @display,
                sort: "quantity_asc"
              ),
              class: modal_link_class %>

        <%= link_to "あいうえお順",
              items_path(
                category_id: params[:category_id],
                display: @display,
                sort: "name_asc"
              ),
              class: modal_link_class %>

        <%= link_to "閉じる",
              items_path(
                category_id: params[:category_id],
                display: @display,
                sort: params[:sort]
              ),
              class: modal_link_class %>
      </div>
    </div>
  <% end %>

  <% if params[:menu] == "display" %>
    <div
      class="<%= modal_wrapper_class %>"
      data-controller="modal"
      data-action="click->modal#close keydown@window->modal#closeWithEscape"
      data-modal-close-url-value="<%= items_path(
        category_id: params[:category_id],
        display: @display,
        sort: params[:sort]
      ) %>">

      <div class="<%= modal_panel_class %>">
        <p class="<%= modal_title_class %>">表示を変更する</p>
        <p class="<%= modal_subtitle_class %>">操作を選択してください</p>

        <%= link_to "在庫数",
              items_path(
                category_id: params[:category_id],
                sort: params[:sort],
                display: "quantity"
              ),
              class: modal_link_class %>

        <%= link_to "期限日",
              items_path(
                category_id: params[:category_id],
                sort: params[:sort],
                display: "expired_at"
              ),
              class: modal_link_class %>

        <%= link_to "購入日",
              items_path(
                category_id: params[:category_id],
                sort: params[:sort],
                display: "purchased_at"
              ),
              class: modal_link_class %>

        <%= link_to "閉じる",
              items_path(
                category_id: params[:category_id],
                sort: params[:sort],
                display: @display
              ),
              class: modal_link_class %>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-[1fr_140px_80px] bg-indigo-100/70 px-8 py-3 font-bold">
    <div>アイテム名</div>

    <div class="text-center">
      <% if @display == "expired_at" %>
        期限日
      <% elsif @display == "purchased_at" %>
        購入日
      <% else %>
        在庫数
      <% end %>
    </div>

    <div></div>
  </div>

  <% if @items.any? %>
    <%= form_with url: bulk_destroy_items_path, method: :delete do %>
      <% @items.each do |item| %>
        <div class="grid grid-cols-[1fr_140px_80px] items-center border-b border-stone-300 bg-white px-8 py-4">
          <div class="flex items-center gap-2">
            <% if params[:select] == "true" %>
              <%= check_box_tag "item_ids[]", item.id, false, class: "h-5 w-5 rounded-full border-stone-900" %>
            <% end %>

            <div>
              <%= link_to item.name, edit_item_path(item), class: "text-base text-stone-900" %>

              <% if item.memo.present? %>
                <p class="mt-1 text-xs text-stone-500">
                  <%= item.memo %>
                </p>
              <% end %>
            </div>
          </div>

          <div class="text-center">
            <% if @display == "expired_at" %>
              <div class="flex justify-center">
                <span class="rounded-lg bg-stone-200 px-3 py-1 font-bold">
                  <%= item.expired_at&.strftime("%Y/%m/%d") || "-" %>
                </span>
              </div>
            <% elsif @display == "purchased_at" %>
              <div class="flex justify-center">
                <span class="rounded-lg bg-stone-200 px-3 py-1 font-bold">
                  <%= item.purchased_at&.strftime("%Y/%m/%d") || "-" %>
                </span>
              </div>
            <% else %>
              <div class="flex items-center justify-center gap-6">
                <%= link_to increase_quantity_item_path(
                              item,
                              category_id: params[:category_id],
                              display: params[:display],
                              sort: params[:sort]
                            ),
                            data: { turbo_method: :patch },
                            class: "flex h-8 w-8 items-center justify-center text-stone-900" do %>
                  <%= heroicon "plus-circle", type: :solid, class: "h-7 w-7" %>
                <% end %>

                <span class="<%= item.quantity.zero? ? 'text-red-600' : 'text-stone-900' %> text-center font-bold">
                  <%= item.quantity %>
                </span>

                <% if item.quantity.positive? %>
                  <%= link_to decrease_quantity_item_path(
                                item,
                                category_id: params[:category_id],
                                display: @display,
                                sort: params[:sort]
                              ),
                              data: { turbo_method: :patch },
                              class: "flex h-8 w-8 items-center justify-center text-stone-900" do %>
                    <%= heroicon "minus-circle", type: :solid, class: "h-7 w-7" %>
                  <% end %>
                <% else %>
                  <span class="text-stone-300">
                    <%= heroicon "minus-circle", type: :solid, class: "h-7 w-7" %>
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>

          <div class="flex justify-start pl-11">
            <% shopping_quantity = @shopping_item_quantities[[item.category_id, item.name, item.memo]] || 0 %>

            <%= link_to add_to_shopping_item_item_path(
                          item,
                          category_id: params[:category_id],
                          display: @display,
                          sort: params[:sort]
                        ),
                        data: { turbo_method: :patch },
                        class: "relative inline-flex text-stone-400" do %>
              <%= heroicon "shopping-cart", type: :outline, class: "h-7 w-7" %>

              <span class="absolute -right-2 -top-2 flex h-5 w-5 items-center justify-center rounded-full bg-white text-xs font-bold text-stone-500">
                <% if shopping_quantity.positive? %>
                  <%= shopping_quantity %>
                <% else %>
                  <%= heroicon "plus-circle", type: :solid, class: "h-4 w-4" %>
                <% end %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if params[:select] == "true" %>
        <div class="fixed bottom-24 left-1/2 z-10 flex -translate-x-1/2 gap-4 rounded-2xl bg-white px-5 py-3 text-sm shadow-md">
          <%= submit_tag "全て削除",
                class: "text-stone-900",
                data: { turbo_confirm: "選択したアイテムを削除しますか？" } %>

          <%= button_tag "クリア",
                type: "reset",
                class: "text-stone-900" %>

          <%= link_to "閉じる",
                items_path(category_id: params[:category_id], display: @display, sort: params[:sort]),
                class: "text-stone-900" %>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <div class="flex h-96 items-center justify-center text-xl font-bold">
      アイテムなし
    </div>
  <% end %>
</div>