<h1 class="mb-6 text-2xl font-bold">家の在庫</h1>

<%= form_with url: items_path, method: :get, class: "mb-4 space-y-3" do |f| %>
  <div class="flex gap-2">
    <%= f.text_field :keyword,
          value: params[:keyword],
          placeholder: "商品名を入力",
          class: "w-full rounded-lg border border-stone-300 px-3 py-2 text-sm" %>

    <%= f.submit "検索",
          class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white" %>
  </div>

  <%= f.select :sort,
        [
          ["購入が新しい順", "purchased_desc"],
          ["購入が古い順", "purchased_asc"],
          ["在庫数が多い順", "quantity_desc"],
          ["在庫数が少ない順", "quantity_asc"],
          ["あいうえお順", "name_asc"]
        ],
        { include_blank: "並び替えを選択" },
        {
          selected: params[:sort],
          class: "w-full rounded-lg border border-stone-300 px-3 py-2 text-sm"
        } %>
<% end %>

<div class="mb-4 flex justify-end">
  <%= link_to "新規作成",
        new_item_path,
        class: "rounded-lg bg-stone-900 px-4 py-2 text-sm font-semibold text-white" %>
</div>

<%= form_with url: bulk_destroy_items_path, method: :delete do %>
  <div class="space-y-3">
    <% @items.each do |item| %>
      <div class="rounded-xl border border-stone-200 bg-white p-4 shadow-sm">
        <div class="flex items-start gap-3">
          <%= check_box_tag "item_ids[]", item.id, false, class: "h-4 w-4" %>

          <% if item.image.attached? %>
            <%= image_tag item.image, class: "h-20 w-20 rounded-xl object-cover" %>
          <% else %>
            <div class="flex h-20 w-20 items-center justify-center rounded-xl bg-stone-100 text-xs text-stone-400">
              No image
            </div>
          <% end %>

          <div class="min-w-0 flex-1">
            <div class="mb-1 flex items-center gap-2">
              <p class="truncate text-lg font-semibold"><%= item.name %></p>

              <span class="rounded-full bg-stone-100 px-2 py-1 text-xs text-stone-600">
                <%= item.category.name %>
              </span>
            </div>

            <div class="mt-2">
              <span class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-sm font-semibold text-blue-700">
                在庫数：<%= item.quantity %>
              </span>
            </div>

            <div class="mt-4 flex gap-2">
              <%= link_to "編集",
                    edit_item_path(item),
                    class: "rounded-lg border border-blue-200 px-3 py-1.5 text-sm font-semibold text-blue-600" %>

              <%= link_to "削除",
                    item_path(item),
                    class: "rounded-lg border border-red-200 px-3 py-1.5 text-sm font-semibold text-red-600",
                    data: {
                      turbo_method: :delete,
                      turbo_confirm: "本当に削除しますか？"
                    } %>

              <%= link_to "消費",
                    consume_item_path(item),
                    class: "rounded-lg border border-green-200 px-3 py-1.5 text-sm font-semibold text-green-700",
                    data: {
                      turbo_method: :patch,
                      turbo_confirm: "本当に消費しますか？"
                    } %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%= submit_tag "選択したアイテムを削除",
        class: "mt-4 w-full rounded-lg border border-red-300 bg-white px-4 py-2 text-sm font-semibold text-red-600",
        data: {
          turbo_confirm: "選択したアイテムを削除しますか？"
        } %>
<% end %>