<h1 class="mb-8 text-2xl font-bold">家の在庫</h1>

<%= form_with url: items_path, method: :get, class: "mb-5 space-y-4" do |f| %>
  <div class="flex gap-2">
    <%= f.text_field :keyword,
          value: params[:keyword],
          placeholder: "商品名を入力",
          class: "min-h-12 w-full rounded-xl border border-stone-300 bg-white px-4 text-base" %>

    <%= f.submit "検索",
          class: "rounded-xl bg-blue-600 px-5 text-base font-semibold text-white" %>
  </div>

  <%= f.select :sort,
        [
          ["購入が新しい順", "purchased_desc"],
          ["購入が古い順", "purchased_asc"],
          ["在庫数が多い順", "quantity_desc"],
          ["在庫数が少ない順", "quantity_asc"],
          ["あいうえお順", "name_asc"]
        ],
        { include_blank: "並び替えを選択" },
        {
          selected: params[:sort],
          class: "min-h-12 w-full rounded-xl border border-stone-300 bg-white px-4 text-base"
        } %>
<% end %>

<div class="mb-6 flex justify-end">
  <%= link_to "新規作成",
        new_item_path,
        class: "rounded-xl bg-stone-900 px-6 py-3 text-base font-semibold text-white shadow-sm" %>
</div>

<%= form_with url: bulk_destroy_items_path, method: :delete do %>
  <div class="space-y-4">
    <% @items.each do |item| %>
      <div class="rounded-2xl border border-stone-200 bg-white p-5 shadow-md">
        <div class="flex items-start gap-4">
          <%= check_box_tag "item_ids[]", item.id, false, class: "mt-1 h-5 w-5 rounded border-stone-300" %>

          <% if item.image.attached? %>
            <%= image_tag item.image, class: "h-24 w-24 rounded-2xl object-cover" %>
          <% else %>
            <div class="flex h-24 w-24 shrink-0 items-center justify-center rounded-2xl bg-stone-100 text-sm text-stone-400">
              No image
            </div>
          <% end %>

          <div class="min-w-0 flex-1">
            <div class="mb-2 flex items-center gap-2">
              <p class="truncate text-xl font-bold"><%= item.name %></p>

              <span class="shrink-0 rounded-full bg-stone-100 px-3 py-1 text-xs text-stone-600">
                <%= item.category.name %>
              </span>
            </div>

            <div>
              <span class="inline-flex rounded-full bg-blue-50 px-4 py-1 text-base font-semibold text-blue-700">
                在庫数：<%= item.quantity %>
              </span>
            </div>

            <div class="mt-5 flex flex-wrap gap-3">
              <%= link_to "編集",
                    edit_item_path(item),
                    class: "rounded-xl border border-blue-200 px-4 py-2 text-base font-semibold text-blue-600" %>

              <%= link_to "削除",
                    item_path(item),
                    class: "rounded-xl border border-red-200 px-4 py-2 text-base font-semibold text-red-600",
                    data: {
                      turbo_method: :delete,
                      turbo_confirm: "本当に削除しますか？"
                    } %>

              <%= link_to "消費",
                    consume_item_path(item),
                    class: "rounded-xl border border-green-200 px-4 py-2 text-base font-semibold text-green-700",
                    data: {
                      turbo_method: :patch,
                      turbo_confirm: "本当に消費しますか？"
                    } %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%= submit_tag "選択したアイテムを削除",
        class: "mt-6 w-full rounded-xl border border-red-300 bg-white px-4 py-3 text-base font-semibold text-red-600",
        data: {
          turbo_confirm: "選択したアイテムを削除しますか？"
        } %>
<% end %>